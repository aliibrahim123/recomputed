---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection } from 'astro:content';
import type { FSItem, FSDir } from '../components/ArticleTree.astro';
import ArticleTree from '../components/ArticleTree.astro';
import type { MarkdownHeading } from 'astro';

let articles = await getCollection('docs');
let index = new Map<string, FSItem>();
for (let article of articles) {
	let dir = index;
	let parts = article.id.split('/');
	for (let part of parts.slice(0, -1)) {
		if (dir.has(part)) dir = (dir.get(part) as FSDir).children;
		else {
			let item: FSItem = { type: 'dir', children: new Map(), id: part };
			dir.set(part, item);
			dir = item.children;
		}
	}
	dir.set(article.data.title, { type: 'file', path: '/recomputed/' + article.id });
}

let headers: MarkdownHeading[] = [];
function header_walker(item: FSItem, depth: number) {
	if (item.type == 'file') return;
	headers.push({ depth, text: item.id!, slug: item.id! });
	for (let [name, child] of item.children) header_walker(child, depth + 1);
}
for (let item of index.values()) header_walker(item, 1);
---

<StarlightPage frontmatter={{ title: 'Index' }} headings={headers}>
	<ArticleTree tree={index} />
</StarlightPage>
