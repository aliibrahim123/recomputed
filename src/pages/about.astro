---
import { Code } from '@astrojs/starlight/components';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection } from 'astro:content';
import { projects } from './projects.astro';

let info = `
> aboutfetch
name: ali ibrahim
birth: 2006
role: undergraduate student
location: lebanon

favorites:
	language: rust
	linux_distro: opensuse slowroll
	cpu_architecture: arm64
	programming_paradigm: trait oriented, matching and mapping

domains: 
	major: logic design, language design
	minor: web development

social: 
	github: aliibrahim123
	email: ali.ibrahim.dev.1548@gmail.com
	reddit: u/ali_compute_unit

workspace:
	desktop environment: plasma
	ide: vscode
	terminal: konsole
	shell: fish
	ai_assistant: codeium

milestones:
	cpu_isas: teep, mep
	programming_languages: unimap, gramex
	frameworks: neoview (x5)
	data_formats: structom
	project_count: ${projects.length}
	article_count: ${(await getCollection('docs')).length}
	devilish_creations: teep
`.trim();
---

<StarlightPage frontmatter={{ title: 'About', template: 'splash' }}>
	<Code code={info} lang="yaml" />
</StarlightPage>
